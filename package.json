{
  "name": "vulnerable-mcp-server",
  "version": "1.0.0",
  "description": "An intentionally vulnerable MCP server for security testing, education, and CTF challenges",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:http": "node dist/index.js --transport http",
    "start:ws": "node dist/index.js --transport websocket",
    "start:all": "node dist/index.js --transport all",
    "test": "vitest",
    "test:exploits": "vitest run tests/exploits",
    "setup:db": "node scripts/setup-database.js",
    "setup:certificates": "node scripts/generate-certificates.js",
    "reset": "node scripts/reset-environment.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "vulnerable",
    "security",
    "ctf",
    "educational",
    "penetration-testing",
    "security-testing"
  ],
  "author": "IntegSec <contact@integsec.com> (https://integsec.com)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/integsec/vulnerable-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/integsec/vulnerable-mcp-server/issues"
  },
  "homepage": "https://integsec.com",
  "warnings": {
    "security": "⚠️  THIS IS AN INTENTIONALLY VULNERABLE APPLICATION ⚠️",
    "disclaimer": "This server contains multiple security vulnerabilities by design. DO NOT use in production or with real data!",
    "purpose": "Educational and security testing purposes only"
  }
}
